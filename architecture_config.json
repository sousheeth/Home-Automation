{
  "system_gateway": {
    "broker_protocol": "MQTT",
    "port": 1883,
    "keepalive_interval_seconds": 60,
    "ssl_encryption": true
  },
  "iot_device_registry": [
    {
      "device_id": "ESP32_LIVING_ROOM_TEMP",
      "device_type": "Sensor",
      "hardware": "ESP32-WROOM-32",
      "firmware_version": "v1.2.4",
      "data_protocol": "MQTT",
      "topics_published": ["home/livingroom/temperature", "home/livingroom/humidity"],
      "sampling_rate_seconds": 15
    },
    {
      "device_id": "RASPBERRY_PI_CENTRAL_HUB",
      "device_type": "Gateway/Controller",
      "hardware": "Raspberry Pi 4 Model B",
      "os": "Raspbian Lite v11",
      "database_storage": "InfluxDB (Time-Series)",
      "subscribed_topics": ["home/#"]
    },
    {
      "device_id": "SMART_RELAY_LIGHTING",
      "device_type": "Actuator",
      "hardware": "Shelly 1PM",
      "topics_subscribed": ["home/livingroom/lights/switch"],
      "max_load_amperes": 16
    }
  ],
  "automation_rules": {
    "hvac_threshold_celsius": 24.5,
    "energy_saving_mode": "enabled",
    "idle_timeout_minutes": 30
  }
}
